# Copy to .env and fill in production values.
# Never commit real secrets.

# Django
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Local Docker without TLS termination:
DJANGO_SECURE_SSL_REDIRECT=false
# Behind HTTPS reverse proxy set to true and ensure X-Forwarded-Proto is set:
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=31536000

# PostgreSQL
POSTGRES_DB=fast_plan
POSTGRES_USER=fast_plan
POSTGRES_PASSWORD=replace-with-strong-db-password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Browser origins (SPA)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Reminder scheduler loop (seconds)
REMINDER_INTERVAL_SECONDS=3600
