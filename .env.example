# Copy to .env and fill in production values.
# Never commit real secrets.

# Django
DJANGO_DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Local Docker without TLS termination:
DJANGO_SECURE_SSL_REDIRECT=false
# Behind HTTPS reverse proxy set to true and ensure X-Forwarded-Proto is set:
# DJANGO_SECURE_SSL_REDIRECT=true
# DJANGO_SECURE_HSTS_SECONDS=31536000
# Cookie Secure flag (defaults off when DJANGO_SECURE_SSL_REDIRECT=false):
# DJANGO_COOKIE_SECURE=false

# PostgreSQL
POSTGRES_DB=fast_plan
POSTGRES_USER=fast_plan
POSTGRES_PASSWORD=replace-with-strong-db-password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Browser origins (SPA)
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Reminder scheduler loop (seconds) — also used as the Celery beat interval
REMINDER_INTERVAL_SECONDS=3600
# CRM schedule.daily automations (default once per day)
# CRM_DAILY_AUTOMATION_SECONDS=86400
# Omnichannel IMAP/Telegram sync interval (default 15 min)
# CRM_CHANNEL_SYNC_SECONDS=900

# Frontend absolute URL (invite / password-reset / digest links)
FRONTEND_BASE_URL=http://localhost:8080

# Redis (cache backend + Celery broker/result backend + SSE pub/sub). Leave
# empty to fall back to LocMemCache, eager Celery, and in-process SSE — fine
# for local/single-worker; required for multi-worker gunicorn realtime.
REDIS_URL=redis://redis:6379/1
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Run Celery tasks synchronously in-process instead of via a worker (dev only):
CELERY_TASK_ALWAYS_EAGER=false

# Optional error tracking (no-op unless sentry-sdk is installed and DSN set)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Max size (bytes) accepted for WBS/card file attachments
ATTACHMENT_MAX_BYTES=5242880
# Max profile avatar size (bytes)
AVATAR_MAX_BYTES=2097152

# Structured logging level
LOG_LEVEL=INFO

# Email (SMTP). In DEBUG default is console backend.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=Fast Plan <noreply@example.com>

# Optional AI drafts (OpenAI first, then Ollama, else built-in heuristics)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Local host Ollama:
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# Docker Compose profile `ai` (backend talks to the ollama service):
#   docker compose --profile ai up -d
#   set OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2
